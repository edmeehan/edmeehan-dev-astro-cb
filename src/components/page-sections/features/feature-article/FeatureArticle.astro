---
import Button from "@core-elements/button/Button.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import CustomSection from "@page-sections/builders/custom-section/CustomSection.astro";
import { getCollection } from "astro:content";

const {
  post: postPath = "",
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "4xl",
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;

const allPosts = await getCollection("blog");

// CloudCannon document picker stores the full path; match against post.id (filename only)
const postId = postPath.split("/").pop() ?? "";
const normalizedPath = postId.replace(/\.(mdx?|ya?ml|json)$/, "");
const post = allPosts.find((p) => p.id === normalizedPath);

console.log(allPosts)

const slug = post ? (post.id?.replace(/\.mdx?$/, "") || post.slug) : null;
const pubDate = post?.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<CustomSection
  class:list={["feature-article", className]}
  maxContentWidth="xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  {
    post ? (
      <div class="feature-article-layout">
        {post.data.image && (
          <Image
            class="feature-article-image"
            source={post.data.image}
            alt={post.data.title}
            aspectRatio="landscape"
            rounded={true}
          />
        )}
        <div class="feature-article-content">
          <SimpleText
            size="sm"
            class="feature-article-meta"
          >
            {pubDate}{post.data.author ? ` • ${post.data.author}` : ""}
          </SimpleText>
          <Heading
            level="h2"
            size="xl"
            class="feature-article-heading"
          >
            {post.data.title}
          </Heading>
          {post.data.description && (
            <SimpleText
              class="feature-article-description"
              text={post.data.description}
            />
          )}
          <Button
            class="feature-article-button"
            text="Read article"
            link={`/blog/${slug}`}
            variant="primary"
            size="md"
          />
        </div>
      </div>
    ) : (
      _component && (
        <SimpleText
          class="feature-article-empty"
          text="Select a blog post to feature."
        />
      )
    )
  }
</CustomSection>

<style>
  @layer page-sections {
    .feature-article-layout {
      display: grid;
      gap: var(--spacing-2xl);
      grid-template-columns: 1fr 1fr;
      align-items: center;

      @media (width < 720px) {
        grid-template-columns: 1fr;
      }
    }

    .feature-article-image {
      margin-top: 0;
    }

    .feature-article-content {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .feature-article-meta {
      color: var(--color-text-muted);
      margin-top: 0;
    }

    .feature-article-heading {
      margin-top: 0;
    }

    .feature-article-description {
      color: var(--color-text-muted);
      margin-top: 0;
    }

    .feature-article-button {
      align-self: flex-start;
      margin-top: var(--spacing-sm);
    }

    .feature-article-empty {
      color: var(--color-text-muted);
      font-style: italic;
    }
  }
</style>
