---
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Text from "@core-elements/text/Text.astro";
import Card from "@wrappers/card/Card.astro";
import GridItem from "@wrappers/grid/GridItem.astro";

const {
  testimonial = "",
  logo = "",
  logo_alt = "",
  name = "",
  title = "",
  headshot = "",
  headshot_alt = "",
  class: className,
  _component,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  ...htmlAttributes
} = Astro.props;
---

<GridItem
  class="testimonial-item"
  {...htmlAttributes}
>
  <Card
    backgroundColor="none"
    colorScheme="inherit"
    paddingHorizontal="none"
    paddingVertical="none"
  >
    <Text
      alignX="start"
      data-prop="testimonial"
      text={testimonial}
      class="testimonial"
    />
    <Image
      alt={logo_alt}
      aspectRatio="none"
      data-prop="alt"
      positionHorizontal="center"
      positionVertical="center"
      sizes="(max-width: 639px) 100vw, 300px"
      widths={[300, 600]}
      slot="before"
      class="logo"
      source={logo}
    />
    <Fragment slot="after">
      <SimpleText
        alignX="start"
        data-prop="name"
        size="md"
        text={name}
        class="client-name"
      />
      <SimpleText
        alignX="start"
        data-prop="title"
        size="sm"
        text={title}
        class="client-title"
      />
      <Image
        alt={headshot_alt}
        aspectRatio="square"
        data-prop="alt"
        positionHorizontal="center"
        positionVertical="center"
        sizes="(max-width: 1280px) 100vw, 1280px"
        source={headshot}
        class="client-headshot"
      />
    </Fragment>
  </Card>
</GridItem>

<style>
  @import "/src/styles/variables/_breakpoints.css";

  @layer page-sections {
    .testimonial-item {
      .card {
        :global(.card-inner) {
          height: auto;
        }
        :global(.after-content) {
          display: grid;
          grid-template-columns: 80px auto;
          grid-template-rows: auto auto;
          column-gap: var(--spacing-em-md);
        }
      }
      .testimonial {
        :global(.text-inner > p) {
          &:first-child::before {
            content: '“';
            display: inline-block;
          }
          &:last-child::after {
            content: '”';
            display: inline-block;
          }
        }
      }
      .logo {
        :global(img) {
          object-fit: contain;
          max-height: 150px;
          object-position: left center;
        }
      }
      .client-name {
        font-family: var(--font-headings);
        align-self: end;
      }
      .client-title {
        --color-text: var(--color-text-muted);
        align-self: start;
      }
      .client-name,
      .client-title {
        grid-column: 2;
        margin: 0;
      }
      .client-headshot {
        grid-column: 1 / span 1;
        grid-row: 1 / span 2;
        margin: 0;
        border-radius: var(--radius-full);
        align-self: center;
        :global(img) {
          max-height: 80px;
        }
      }
    }
  }
</style>