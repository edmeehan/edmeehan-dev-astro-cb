---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Bar from "@components/navigation/bar/Bar.astro";
import Mobile from "@components/navigation/mobile/Mobile.astro";
import TypefaceLogo from "@core-elements/typeface-logo/TypefaceLogo.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

type NavButton = {
  text?: string;
  href?: string;
  [key: string]: unknown;
};

const {
  logoText,
  brandMessage,
  navData = [],
  buttonSections = [] as NavButton[],
  class: className,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const mobileNavData = [
  ...navData,
  ...buttonSections.map((button: NavButton) => ({
    name: button.text || "Button",
    path: button.href || "#",
    children: [],
  })),
];
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  backgroundColor="none"
  class:list={["main-nav", className]}
  {...htmlAttributes}
  useDefaultEditableBinding={false}
>
  <a href="/">
    <TypefaceLogo
      logoText={logoText}
      brandMessage={brandMessage}
    />
  </a>
  <div class="nav-end">
    <Bar
      navData={navData}
      class="desktop-main-nav"
    />

    <ButtonGroup
      direction="row"
      align="center"
      class="desktop-button-group"
      buttonSections={buttonSections}
      useDefaultEditableBinding={false}
    />
  </div>
  <Mobile
    logoText={logoText}
    brandMessage={brandMessage}
    navData={mobileNavData}
    class="mobile-main-nav"
    useDefaultEditableBinding={false}
  />
</CustomSection>

<style is:global>
  @layer page-sections {
    .main-nav {
      padding-block: var(--spacing-2xl);
      position: sticky;
      top: 0;
      z-index: var(--layer-2);
      transition: all var(--animation-normal) ease;

      &.scrolled-below-fold {
        background-color: var(--color-bg);

        &.is-scrolled {
          padding-block: var(--spacing-md);
        }
      }

      &:not(.scrolled-below-fold) {
        > .outer-content > .content > .nav-end {
          opacity: 0;
        }
      }

      .desktop-main-nav,
      .desktop-button-group.button-group {
        @container (max-width: 768px) {
          display: none;
        }
      }

      .main-nav-logo {
        margin-top: 0 !important;
      }

      .nav-hamburger.mobile-button {
        @container (min-width: 769px) {
          display: none;
        }
      }

      > .outer-content > .content {
        align-items: center;
        container-type: inline-size;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);

        > a > .image img {
          height: 1.8em;
          max-width: min(20em, 100%);
          width: auto;
        }

        .button-group {
          margin-top: 0;
        }
      }

      > .outer-content > .content > .nav-end {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        justify-content: flex-end;
        margin-left: auto;
        transition: all var(--animation-slow) ease;

        > .button-group {
          container-type: normal;
        }
      }
    }
  }
</style>

<script>
  // Disable scroll anchoring — prevents the browser from adjusting scrollY
  // when the nav's padding changes, which would cause a false scroll event
  // that immediately reverses the is-scrolled toggle.
  document.documentElement.style.overflowAnchor = "none";

  const nav = document.querySelector(".main-nav");
  let lastY = window.scrollY;

  window.addEventListener("scroll", () => {
    const currentY = window.scrollY;
    const diff = currentY - lastY;
    const threshold = window.innerHeight * 0.5;

    nav?.classList.toggle("is-scrolled", diff > 0);
    nav?.classList.toggle("scrolled-below-fold", currentY > threshold);

    lastY = currentY;
  }, { passive: true });
</script>
